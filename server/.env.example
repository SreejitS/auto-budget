# Auto-Budget API Key (for iPhone Shortcuts authentication)
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
AUTO_BUDGET_API_KEY=change-me-to-a-random-string

# Firefly III Personal Access Token
FIREFLY_API_TOKEN=your-firefly-token-here

# Anthropic API Key (optional, for AI categorization)
# Without this, keyword rules handle ~90% of merchants
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx
